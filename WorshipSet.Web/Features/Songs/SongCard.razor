@using WorshipSet.Domain.Songs

<div class="group relative overflow-hidden rounded-[2rem] border border-neutral-200 bg-surface shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-xl">

	@if (Song.ImagePaths != null && Song.ImagePaths.Count > 0)
	{
		<img src="@Song.ImagePaths[0]"
			 class="h-40 w-full object-cover" />
	}
	else
	{
		<div class="flex h-40 w-full items-center justify-center bg-primary-900 text-3xl font-semibold text-gold-500">
			♪
		</div>
	}

	<div class="p-6">
		<div class="flex items-start justify-between gap-4">
			<div class="min-w-0">
				<h3 class="truncate text-xl font-semibold tracking-tight text-primary-900">
					@Song.Title
				</h3>

				@if (!string.IsNullOrWhiteSpace(Song.Composer))
				{
					<div class="mt-1 truncate text-sm font-medium text-neutral-500">
						@Song.Composer
					</div>
				}
				else
				{
					<div class="mt-1 text-sm text-neutral-400">
						Unknown composer
					</div>
				}
			</div>

			<div class="rounded-full bg-gold-100 px-3 py-1 text-xs font-semibold tracking-[0.14em] text-gold-700 uppercase">
				Song
			</div>
		</div>

		@if (Song.ImagePaths != null && Song.ImagePaths.Count > 1)
		{
			<div class="mt-4 text-xs font-semibold tracking-[0.14em] text-neutral-400 uppercase">
				@Song.ImagePaths.Count images
			</div>
		}

		<div class="mt-6 flex items-center justify-between border-t border-neutral-200 pt-5">
			<div class="text-xs font-semibold tracking-[0.14em] text-neutral-400 uppercase">
				WorshipSet
			</div>

			<a href="@($"{Navigation.Songs}/{Song.Id}")"
				   class="inline-flex items-center justify-center rounded-xl bg-primary-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary-800">
				View
			</a>
		</div>
	</div>
</div>

@code {
	[Parameter, EditorRequired]
	public required Song Song { get; set; }
}