@attribute [Route(Navigation.Songs)]

@using WorshipSet.Application.Features.Songs
@using WorshipSet.Domain.Songs

@inject ISongRepository SongRepository

<PageTitle>Songs</PageTitle>

<div class="min-h-screen bg-neutral-100">
	<div class="mx-auto max-w-7xl px-6 py-8 lg:px-8">
		<div class="mb-8 flex items-start justify-between gap-6">
			<div>
				<div class="inline-flex items-center rounded-full border border-gold-500/30 bg-surface px-4 py-2 text-xs font-semibold tracking-[0.2em] text-primary-900 uppercase shadow-sm">
					WorshipSet Library
				</div>

				<h1 class="mt-4 text-4xl font-semibold tracking-tight text-primary-900 sm:text-5xl">
					Songs
				</h1>

				<p class="mt-3 max-w-2xl text-base leading-7 text-neutral-600 sm:text-lg">
					Browse your worship library, keep songs organized, and build beautiful sets with confidence.
				</p>
			</div>

			<a href="@(Navigation.Songs + Navigation.AddEdit)"
			   class="inline-flex shrink-0 items-center justify-center rounded-2xl bg-accent-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-accent-500/20 transition hover:bg-accent-600">
				Add Song
			</a>
		</div>

		<div class="mb-8 grid gap-4 sm:grid-cols-3">
			<div class="rounded-3xl border border-neutral-200 bg-surface p-5 shadow-sm">
				<div class="text-sm font-semibold tracking-[0.16em] text-neutral-400 uppercase">
					Total Songs
				</div>
				<div class="mt-2 text-3xl font-semibold text-primary-900">
					@songs.Count
				</div>
				<div class="mt-1 text-sm text-neutral-500">
					In your worship library
				</div>
			</div>

			<div class="rounded-3xl border border-neutral-200 bg-surface p-5 shadow-sm">
				<div class="text-sm font-semibold tracking-[0.16em] text-neutral-400 uppercase">
					Planning Ready
				</div>
				<div class="mt-2 text-3xl font-semibold text-accent-500">
					@songs.Count
				</div>
				<div class="mt-1 text-sm text-neutral-500">
					Available to add to sets
				</div>
			</div>

			<div class="rounded-3xl border border-neutral-200 bg-surface p-5 shadow-sm">
				<div class="text-sm font-semibold tracking-[0.16em] text-neutral-400 uppercase">
					WorshipSet
				</div>
				<div class="mt-2 text-3xl font-semibold text-gold-500">
					Library
				</div>
				<div class="mt-1 text-sm text-neutral-500">
					Curated for your team
				</div>
			</div>
		</div>

		@if (songs.Count == 0)
		{
			<div class="rounded-[2rem] border border-dashed border-neutral-300 bg-surface px-8 py-16 text-center shadow-sm">
				<div class="mx-auto flex h-16 w-16 items-center justify-center rounded-3xl bg-primary-900 text-2xl font-semibold text-gold-500 shadow-sm">
					♪
				</div>

				<h2 class="mt-6 text-2xl font-semibold tracking-tight text-primary-900">
					No songs yet
				</h2>

				<p class="mx-auto mt-3 max-w-xl text-base leading-7 text-neutral-600">
					Start building your worship library by adding your first song.
				</p>

				<div class="mt-8">
					<a href="@Navigation.Songs"
					   class="inline-flex items-center justify-center rounded-2xl bg-primary-900 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-primary-900/20 transition hover:bg-primary-800">
						Add Your First Song
					</a>
				</div>
			</div>
		}
		else
		{
			<div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
				@foreach (var song in songs)
				{
					<SongCard Song="song" />
				}
			</div>
		}
	</div>
</div>

@code {
	List<Song> songs = [];

	protected override async Task OnInitializedAsync()
	{
		songs = await SongRepository.GetAll();
	}
}