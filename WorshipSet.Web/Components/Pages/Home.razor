@page "/"

<PageTitle>WorshipSet</PageTitle>

<div class="min-h-screen bg-neutral-100 text-neutral-900">
	<header class="border-b border-neutral-200 bg-surface/80 backdrop-blur">
		<div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-8">
			<div class="flex items-center gap-4">
				<div class="flex h-12 w-12 items-center justify-center overflow-hidden rounded-2xl bg-primary-900 shadow-sm">
					<span class="text-xl font-bold text-gold-500">WS</span>
				</div>

				<div>
					<div class="text-2xl font-semibold tracking-tight text-primary-900">WorshipSet</div>
					<div class="text-sm text-neutral-500">Your global hub for modern worship music</div>
				</div>
			</div>

			<nav class="hidden items-center gap-8 md:flex">
				<a href="#features" class="text-sm font-medium text-neutral-600 transition hover:text-primary-900">Features</a>
				<a href="#library" class="text-sm font-medium text-neutral-600 transition hover:text-primary-900">Library</a>
				<a href="#teams" class="text-sm font-medium text-neutral-600 transition hover:text-primary-900">Teams</a>
				<a href="#cta" class="text-sm font-medium text-neutral-600 transition hover:text-primary-900">Get Started</a>
			</nav>
		</div>
	</header>

	<section class="relative overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-br from-primary-900/5 via-transparent to-accent-500/10"></div>

		<div class="mx-auto grid max-w-7xl gap-16 px-6 py-20 lg:grid-cols-2 lg:px-8 lg:py-28">
			<div class="relative z-10 flex flex-col justify-center">
				<div class="inline-flex w-fit items-center rounded-full border border-gold-500/30 bg-surface px-4 py-2 text-xs font-semibold tracking-[0.2em] text-primary-900 uppercase shadow-sm">
					Modern worship planning
				</div>

				<h1 class="mt-8 max-w-2xl text-5xl font-semibold tracking-tight text-primary-900 sm:text-6xl">
					Plan meaningful worship with beauty, clarity, and rhythm
				</h1>

				<p class="mt-6 max-w-xl text-lg leading-8 text-neutral-600">
					WorshipSet gives your team a clean, elegant place to organize songs, build service flows, and stay aligned every week.
				</p>

				<div class="mt-10 flex flex-col gap-4 sm:flex-row">
					<a href="/app"
					   class="inline-flex items-center justify-center rounded-2xl bg-primary-900 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-primary-900/20 transition hover:bg-primary-800">
						Open WorshipSet
					</a>

					<a href="#features"
					   class="inline-flex items-center justify-center rounded-2xl border border-primary-900/10 bg-surface px-6 py-3 text-sm font-semibold text-primary-900 shadow-sm transition hover:border-primary-900/20 hover:bg-neutral-50">
						Explore Features
					</a>
				</div>

				<div class="mt-10 grid max-w-lg grid-cols-3 gap-4">
					<div class="rounded-2xl border border-neutral-200 bg-surface p-4 shadow-sm">
						<div class="text-2xl font-semibold text-primary-900">Songs</div>
						<div class="mt-1 text-sm text-neutral-500">Organized by key, theme, and flow</div>
					</div>

					<div class="rounded-2xl border border-neutral-200 bg-surface p-4 shadow-sm">
						<div class="text-2xl font-semibold text-accent-500">Teams</div>
						<div class="mt-1 text-sm text-neutral-500">Keep everyone prepared</div>
					</div>

					<div class="rounded-2xl border border-neutral-200 bg-surface p-4 shadow-sm">
						<div class="text-2xl font-semibold text-gold-500">Sets</div>
						<div class="mt-1 text-sm text-neutral-500">Build polished service plans</div>
					</div>
				</div>
			</div>

			<div class="relative z-10">
				<div class="absolute -top-6 -left-6 h-40 w-40 rounded-full bg-gold-500/10 blur-3xl"></div>
				<div class="absolute -right-10 -bottom-10 h-48 w-48 rounded-full bg-accent-500/10 blur-3xl"></div>

				<div class="relative overflow-hidden rounded-[2rem] border border-neutral-200 bg-surface shadow-2xl">
					<div class="border-b border-neutral-200 bg-neutral-100 px-6 py-4">
						<div class="flex items-center justify-between">
							<div>
								<div class="text-sm font-semibold tracking-[0.2em] text-neutral-400 uppercase">This Sunday</div>
								<div class="mt-1 text-2xl font-semibold text-primary-900">Morning Worship Set</div>
							</div>

							<div class="rounded-full bg-accent-500/10 px-3 py-1 text-xs font-semibold text-accent-500">
								Ready
							</div>
						</div>
					</div>

					<div class="space-y-5 p-6">
						<div class="rounded-3xl bg-primary-900 p-5 text-white">
							<div class="flex items-start justify-between gap-4">
								<div>
									<div class="text-sm tracking-[0.16em] text-white/60 uppercase">Opening</div>
									<div class="mt-2 text-2xl font-semibold">House of the Lord</div>
								</div>

								<div class="rounded-2xl bg-white/10 px-3 py-2 text-sm font-semibold text-gold-300">
									Key of G
								</div>
							</div>
						</div>

						<div class="grid gap-4">
							<div class="flex items-center justify-between rounded-2xl border border-neutral-200 bg-neutral-50 px-5 py-4">
								<div class="font-semibold text-primary-900">Gratitude</div>
								<div class="text-sm font-semibold text-accent-500">B</div>
							</div>

							<div class="flex items-center justify-between rounded-2xl border border-neutral-200 bg-neutral-50 px-5 py-4">
								<div class="font-semibold text-primary-900">Build My Life</div>
								<div class="text-sm font-semibold text-accent-500">D</div>
							</div>
						</div>

						<div class="grid gap-4 sm:grid-cols-2">
							<div class="rounded-2xl border border-neutral-200 bg-surface p-5">
								<div class="text-sm text-neutral-400 uppercase">Team Status</div>
								<div class="mt-2 text-3xl font-semibold text-primary-900">8/8</div>
							</div>

							<div class="rounded-2xl border border-neutral-200 bg-surface p-5">
								<div class="text-sm text-neutral-400 uppercase">Song Library</div>
								<div class="mt-2 text-3xl font-semibold text-primary-900">124</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="library" class="bg-primary-900 text-white">
		<div class="mx-auto max-w-7xl px-6 py-24 lg:px-8">
			<h2 class="text-4xl font-semibold">Your worship music, curated with intention</h2>
			<p class="mt-4 max-w-xl text-white/70">
				Store and discover songs in a library designed for leaders who care about flow and theology.
			</p>
		</div>
	</section>

	<section id="cta" class="bg-surface">
		<div class="mx-auto max-w-4xl px-6 py-24 text-center">
			<h2 class="text-4xl font-semibold text-primary-900">
				A beautiful home for your worship planning
			</h2>

			<div class="mt-10 flex justify-center gap-4">
				<a href="/app"
				   class="rounded-2xl bg-accent-500 px-6 py-3 font-semibold text-white hover:bg-accent-600">
					Get Started
				</a>
			</div>
		</div>
	</section>
</div>